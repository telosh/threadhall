# 開発専用: `docker compose` の web のみ。このファイルでは `npm run dev`（ホットリロード）。
# Cloud Run・Artifact Registry ではルート Dockerfile のみを使うこと。このイメージを GCP に push しない。
#
# Cloud Run は PORT（例: 8080）を注入する。未設定時は 3000（compose 既定と一致）。

FROM node:22-bookworm-slim

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY package.json package-lock.json ./
RUN npm ci

COPY . .

ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
EXPOSE 3000

CMD ["sh", "-c", "exec npm run dev -- --hostname 0.0.0.0 --port \"${PORT}\""]
