# Local libSQL/sqld (see docker-compose.yml)
TURSO_DATABASE_URL=http://127.0.0.1:8080
# Leave empty for local sqld without auth
TURSO_AUTH_TOKEN=

# Better Auth（セッション・OAuth。user/session テーブルは 0005_better_auth.sql）
# openssl rand -base64 32 などで 32 文字以上を推奨
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# GCP なしで Google ログイン UI を emulate する（`genericOAuth` + `/emulate/google`）
# THREADHALL_USE_EMULATE_GOOGLE=1

# 本番・実 IdP: GCP の OAuth 2.0 クライアント（emulate 未使用時）
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Turso Cloud (production / preview)
# TURSO_DATABASE_URL=libsql://<your-database-host>
# TURSO_AUTH_TOKEN=<token>

# Edge 等で @tursodatabase/serverless（compat）を使う場合に 1
# THREADHALL_USE_SERVERLESS_SDK=1

# トップの「試用: 組織作成」フォームをローカルで使うときだけ 1（本番・未認証では無効）
# THREADHALL_ALLOW_DEV_ORG_FORM=1
